{
  "name": "@smartledger.technology/openai-claw",
  "version": "0.6.0",
  "description": "A Claude Code clone powered by OpenAI gpt-5-nano",
  "author": "Gregory J. Ward <codenlighten1@gmail.com> (CTO, SmartLedger.Technology)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codenlighten/openai-claw.git"
  },
  "homepage": "https://github.com/codenlighten/openai-claw#readme",
  "bugs": {
    "url": "https://github.com/codenlighten/openai-claw/issues"
  },
  "keywords": [
    "ai",
    "openai",
    "gpt",
    "agent",
    "cli",
    "claude-code",
    "tools",
    "mcp"
  ],
  "type": "module",
  "bin": {
    "claw": "dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepare": "test -d dist || npm run build",
    "test": "vitest run",
    "eval": "tsx src/eval/cli.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1",
    "@smartledger.technology/ml-dsa": "^0.2.0",
    "@smartledger.technology/openai-claw-verify": "^0.3.0",
    "@smartledger/crypto": "^2.0.0",
    "@smartledger/keys": "^2.0.0",
    "chalk": "^5.3.0",
    "cli-highlight": "^2.1.11",
    "diff": "^5.2.0",
    "dotenv": "^17.2.3",
    "fast-glob": "^3.3.2",
    "gray-matter": "^4.0.3",
    "html-to-text": "^9.0.5",
    "ink": "^5.2.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "minimatch": "^10.1.1",
    "openai": "^4.77.0",
    "pdf-parse": "^2.4.5",
    "react": "^18.3.1",
    "yargs": "^17.7.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/diff": "^5.2.1",
    "@types/html-to-text": "^9.0.4",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.27",
    "@types/yargs": "^17.0.32",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "workspaces": [
    "packages/*"
  ]
}
